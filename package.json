{
  "name": "fz3-box2d-engine",
  "version": "0.0.1",
  "private": true,
  "description": "Bit-exact TypeScript port of Box2DFlash 2.0.2 for the Flaming Zombooka 3 port, plus the golden-trace oracle rig.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "oracle:build": "node tools/oracle/build-harness.mjs",
    "oracle:capture": "node tools/oracle/capture-lines.mjs",
    "assets": "node tools/assets/process-swf.mjs flaming-zombooka-3.swf public/assets/fz3",
    "predev": "npm run assets",
    "dev": "vite",
    "prebuild:web": "npm run assets",
    "build:web": "vite build",
    "render:typecheck": "tsc -p tsconfig.render.json",
    "render:compare": "node tools/render-compare.mjs"
  },
  "dependencies": {
    "openfl": "^9.5.2"
  },
  "devDependencies": {
    "@ruffle-rs/ruffle": "^0.3.0",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "puppeteer": "^23.11.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
