{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "openfl": ["./node_modules/openfl/lib/openfl/index"],
      "openfl/*": ["./node_modules/openfl/lib/openfl/*"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist", "extracted", "tools"]
}
